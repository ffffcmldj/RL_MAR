FUNCTION_BLOCK BookSorting
VAR_INPUT
    RFID1 : BOOL;
    RFID2 : BOOL;
    RFID3 : BOOL;
END_VAR

VAR_OUTPUT
    Motor : BOOL;
    Bin1 : BOOL;
    Bin2 : BOOL;
    Bin3 : BOOL;
END_VAR

// Main logic
Motor := RFID1 OR RFID2 OR RFID3;

Bin1 := RFID1 AND NOT RFID2 AND NOT RFID3;
Bin2 := RFID2 AND NOT RFID1 AND NOT RFID3;
Bin3 := RFID3 AND NOT RFID1 AND NOT RFID2;

END_FUNCTION_BLOCK